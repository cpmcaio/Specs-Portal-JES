@startuml caso_de_uso
title Diagrama de Caso de Uso – Portal JES / SGDU

left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam usecaseBackgroundColor #FEFEFE
skinparam usecaseBorderColor #555555
skinparam actorBorderColor #333333
skinparam ArrowColor #444444

' ──────────── ATORES ────────────
actor "Visitante /\nAtleta" as Visitante
actor "Capitão\n(N1)" as Capitao
actor "Moderador\n(N2)" as Moderador
actor "Administrador\n(N3)" as Admin

Capitao -up-|> Visitante
Moderador -up-|> Capitao
Admin -up-|> Moderador

' ──────────── SISTEMA EXTERNO ────────────
actor "SUAP\n(IFPB)" as SUAP #LightBlue

' ──────────── CASOS DE USO ────────────
rectangle "Portal JES – SGDU" {

  package "Área Pública" {
    usecase "UC01 – Consultar Homepage\n(estatísticas, tabelas, partidas)" as UC01
    usecase "UC02 – Buscar / Filtrar Partidas" as UC02
  }

  package "Autenticação" {
    usecase "UC03 – Autenticar no Sistema\n(matrícula + senha)" as UC03
    usecase "UC04 – Trocar Senha\nno Primeiro Acesso" as UC04
  }

  package "Capitão (N1)" {
    usecase "UC05 – Manter Atletas\n(cadastrar, editar, consultar)" as UC05
    usecase "UC06 – Manter Equipes\n(criar, editar, consultar)" as UC06
  }

  package "Moderador (N2)" {
    usecase "UC07 – Manter Capitão\n(promover atleta a Capitão)" as UC07
    usecase "UC08 – Manter Atléticas\n(cadastrar, editar, consultar)" as UC08
    usecase "UC09 – Manter Modalidades\n(cadastrar limites mín/máx)" as UC09
    usecase "UC10 – Gerenciar Partidas\n(equipes, data, local, fase, status)" as UC10
    usecase "UC11 – Carregar Planilha\n(população em lote com validação)" as UC11
    usecase "UC12 – Gerar Súmula\nAutomática" as UC12
  }

  package "Administrador (N3)" {
    usecase "UC13 – Manter Moderadores\n(cadastrar com senha padrão)" as UC13
    usecase "UC14 – Gerenciar Backup\ne Configurações Globais" as UC14
    usecase "UC15 – Visualizar Estatísticas\nEstratégicas" as UC15
  }

  package "Sistema / Automação" {
    usecase "UC16 – Validar Vínculo\nAcadêmico" as UC16
    usecase "UC17 – Gerar Hash de Senha\n(PBKDF2 + salt)" as UC17
  }
}

' ──────────── ASSOCIAÇÕES ────────────
Visitante --> UC01
Visitante --> UC02

Capitao --> UC03
UC03 ..> UC04 : <<include>>\n[primeiro acesso]

Capitao --> UC05
Capitao --> UC06

Moderador --> UC07
Moderador --> UC08
Moderador --> UC09
Moderador --> UC10
Moderador --> UC11
UC10 ..> UC12 : <<include>>\n[ao criar partida]
UC11 ..> UC12 : <<extend>>\n[partidas em lote]

Admin --> UC13
Admin --> UC14
Admin --> UC15

UC05 ..> UC16 : <<extend>>\n[validação de matrícula]
UC16 --> SUAP

UC03 ..> UC17 : <<include>>
UC04 ..> UC17 : <<include>>

@enduml
